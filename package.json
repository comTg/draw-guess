{
  "name": "draw-guess",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "无服务器双人联机你画我猜 (React + Capacitor)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "cap:sync": "vite build && cap sync android",
    "cap:open": "cap open android",
    "android:apk": "vite build && cap sync android && cd android && gradlew.bat assembleDebug",
    "test:signaling": "node --experimental-strip-types scripts/test-signaling.ts",
    "test:webrtc": "tsx scripts/test-webrtc.ts",
    "test:draw": "tsx scripts/test-draw-sync.ts",
    "test:game": "tsx scripts/test-game-engine.ts",
    "test:reconnect": "tsx scripts/test-reconnect.ts",
    "test": "tsx scripts/test-draw-sync.ts && tsx scripts/test-game-engine.ts && tsx scripts/test-reconnect.ts && node --experimental-strip-types scripts/test-signaling.ts"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/status-bar": "^6.0.3",
    "@fontsource/fredoka": "^5.2.10",
    "@fontsource/nunito": "^5.2.7",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "nanoid": "^5.0.9",
    "pako": "^2.1.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@types/pako": "^2.0.3",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "node-datachannel": "^0.32.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
